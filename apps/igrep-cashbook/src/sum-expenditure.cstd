(import lib { parseLine readStreamsFromArgv readUtf8Lines continueIfNonItem})

(let expenditure 0)
(forEach reader (readStreamsFromArgv process.argv)
  (const lines (async.await (readUtf8Lines reader)))
  (forEach [i l] (lines.entries)
    (const n (plusF i 1))
    (const result (parseLine n l))
    ...(continueIfNonItem result)
    (const {isIncome amount} result)
    (if (not isIncome)
      (assign expenditure (plusF expenditure amount)))))
(console.log expenditure)
