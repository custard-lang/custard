{
  "name": "custard",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "custard": "node ./packages/command/dist/custard.js",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rimraf -g \"packages/**/dist\" \"packages/**/*.tsbuildinfo\" \"*.tsbuildinfo\"",
    "test": "pnpm run -r test",
    "test:detailed": "pnpm run test -- --reporter verbose",
    "test:once": "pnpm run test -- run",
    "test:coverage": "pnpm run test -- run --coverage",
    "lint": "eslint packages",
    "fix:lint": "eslint --fix .",
    "format": "prettier --write */*/src/**/*.ts",
    "prepare": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-love": "^154.0.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-no-ignore-returned-union": "^0.6.3",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@11.5.1"
}
